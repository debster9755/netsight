# ── AI (required) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Grafana (optional — uses mock data if not set) ────────────────────────────
GRAFANA_URL=
GRAFANA_API_TOKEN=

# ── Live packet capture ────────────────────────────────────────────────────────
# Run backend with sudo to enable live capture.
# Set the network interface to sniff on.
CAPTURE_INTERFACE=en0

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:5173
